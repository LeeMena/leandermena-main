# ─────────────────────────────────────────────────────────────
# leandermena.com — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and must never be committed.
# In production, set these in Cloudflare Pages → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for canonical links and og:url generation)
# No trailing slash.
VITE_SITE_URL=https://www.leandermena.com

# Contact form endpoint (Cloudflare Worker or Pages Function)
# Defaults to /api/contact (Pages Function) if not set.
VITE_CONTACT_ENDPOINT=https://contact.leandermena.com

# Calendly / booking embed URL (used on the /book page)
VITE_CALENDLY_URL=https://calendly.com/leandermena

# ─── Optional / Future ───────────────────────────────────────

# Plausible Analytics is loaded directly in index.html and needs no env var.
# If you switch to a self-hosted Plausible instance, set the script src here:
# VITE_PLAUSIBLE_SRC=https://plausible.yourserver.com/js/script.js

# Stripe publishable key (if/when e-commerce is added to /shop)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

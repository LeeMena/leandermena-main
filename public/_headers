# Cloudflare Pages: HTTP response headers
# https://developers.cloudflare.com/pages/configuration/headers/

# Security headers on every response
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  X-XSS-Protection: 1; mode=block
  # HSTS: 1 year, subdomains included. Deliberately NOT preloaded -
  # preload is hard to reverse (browser-preload-list submission).
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  # CSP in REPORT-ONLY mode: observes violations in the browser console
  # without blocking anything, so it can never break Calendly bookings,
  # Plausible, Google Fonts, or Unsplash imagery. Staging step before an
  # enforced policy - watch devtools for a clean run, then switch the
  # header name to Content-Security-Policy. Host list derived from every
  # external origin the app talks to (script/style/font/img/connect/frame).
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://plausible.io https://assets.calendly.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https://images.unsplash.com; connect-src 'self' https://plausible.io https://contact.leandermena.com https://blueprint-lead-capture.httpsskytabtechupdate011pagesdev.workers.dev; frame-src https://calendly.com https://assets.calendly.com; base-uri 'self'; form-action 'self'; object-src 'none'; frame-ancestors 'self'

# Aggressive cache for hashed static assets (Vite fingerprints filenames)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Images: 30-day cache
/images/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

# Fonts from public dir (if any): 1 year
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# HTML: always revalidate so deploys propagate immediately
/*.html
  Cache-Control: no-cache, must-revalidate

# Root HTML entry point
/
  Cache-Control: no-cache, must-revalidate
